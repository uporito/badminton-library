# Absolute path to the folder where match video files are stored.
# All videoPath values in the DB are relative to this root.
# VIDEO_ROOT=

# Optional: Google Drive. JSON content of service account key (single-line).
# GOOGLE_SERVICE_ACCOUNT_KEY=

# Optional: YouTube Data API v3 key for importing YouTube videos.
# Create one at https://console.cloud.google.com/apis/credentials (enable YouTube Data API v3 first).
# YOUTUBE_API_KEY=

# Optional: URL for the Python CV analysis service (default: http://127.0.0.1:8100).
# Start it with: cd cv_service && python main.py
# CV_SERVICE_URL=http://127.0.0.1:8100
